  @@index([caseId, preservedAt])
  @@index([fileHash])
  @@index([expiresAt, legalHold])
}

model DataRetentionRule {
  id            String    @id @default(cuid())
  category      String    @unique
  status        String    @default("PENDING")
  action        String?
  retentionDays Int?
  legalBasis    String?
  notes         String?   @db.Text
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

model DataDeletionJob {
  id               String    @id @default(cuid())
  userId           String
  privacyRequestId String?
  status           String    @default("PENDING")
  mode             String    @default("EXECUTE")
  scope            Json
  preservation     Json?
  attempts         Int       @default(0)
  maxAttempts      Int       @default(5)
  nextAttemptAt    DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  legalHold        Boolean   @default(false)
  legalHoldReason  String?   @db.Text
  errorSummary     String?   @db.Text
  receiptHash      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user  User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  items DataDeletionJobItem[]

  @@index([userId, createdAt])
  @@index([status, nextAttemptAt])
}

model DataDeletionJobItem {
  id            String    @id @default(cuid())
  jobId         String
  itemKey       String
  status        String    @default("PENDING")
  attempts      Int       @default(0)
  details       Json?
  error         String?   @db.Text
  nextAttemptAt DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  job DataDeletionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, itemKey])
  @@index([status, nextAttemptAt])
  @@index([jobId, status])
}

model LegacyMediaMigrationJob {
  id               String    @id @default(cuid())
  status           String    @default("PLANNED")
  mode             String    @default("STAGE")
  manifestHash     String    @unique
  totalItems       Int       @default(0)
  processedItems   Int       @default(0)
  failedItems      Int       @default(0)
  approvedById     String?
  approvalReason   String?   @db.Text
  rollbackManifest Json?
  errorSummary     String?   @db.Text
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  items LegacyMediaMigrationItem[]

  @@index([status, createdAt])
}

model LegacyMediaMigrationItem {
  id               String    @id @default(cuid())
  jobId            String
  referenceType    String
  referenceId      String
  field            String
  ownerId          String?
  sourceBucket     String
  sourcePath       String
  sourceUrl        String    @db.Text
  sourceVisibility String?
  action           String
  status           String    @default("PLANNED")
  targetAssetId    String?
  fileHash         String?
  snapshot         Json?
  error            String?   @db.Text
  stagedAt         DateTime?
  finalizedAt      DateTime?
  rolledBackAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  job LegacyMediaMigrationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, referenceType, referenceId, field, sourcePath])
  @@index([jobId, status])
  @@index([targetAssetId])
  @@index([sourceBucket, sourcePath])
}

model PublicationRequirement {
  id                 String    @id @default(cuid())
  key                String    @unique
  information        String
  reason             String    @db.Text
  owner              String?
  status             String    @default("PENDING")
  dueAt              DateTime?
  documentKey        String?
  affectedFeature    String?
  value              String?   @db.Text
  requiredForPublish Boolean   @default(true)
  completedAt        DateTime?
  completedById      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  history PublicationRequirementHistory[]

  @@index([status, dueAt])
  @@index([documentKey, status])
}

model PublicationRequirementHistory {
  id            String   @id @default(cuid())
  requirementId String
  actorId       String?
  fromStatus    String?
  toStatus      String?
  previousValue String?  @db.Text
  nextValue     String?  @db.Text
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  requirement PublicationRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId, createdAt])
}

model SecurityIncident {
  id                 String    @id @default(cuid())
  protocol           String    @unique
  title              String
  category           String
  status             String    @default("OPEN")
  discoveredAt       DateTime
  occurredAt         DateTime?
  systemsAffected    Json
  dataCategories     Json
  affectedSubjects   Int?
  riskAssessment     String?   @db.Text
  relevantHarm       Boolean?
  containment        String?   @db.Text
  investigation      String?   @db.Text
  correctiveMeasures String?   @db.Text
  notificationDueAt  DateTime?
  anpdNotifiedAt     DateTime?
  subjectsNotifiedAt DateTime?
  ownerId            String?
  evidence           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status, discoveredAt])
  @@index([notificationDueAt])
}
