generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProfessionalStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  SUSPENDED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum UserRole {
  GUEST
  HOST
  ADMIN
}

enum UserCategory {
  HETERO
  TRANS
  MULHER
  HOMEM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  CANCELLED
  EXPIRED
  CHARGEBACK
  FAILED
}

enum PropertyStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  REJECTED
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  VILLA
  LOFT
  FARM
  HOTEL
  OTHER
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportReason {
  ILLEGAL_CONTENT
  FAKE_PROFILE
  HARASSMENT
  SCAM
  INAPPROPRIATE_CONTENT
  FAKE_DOCUMENTS
  OTHER
}

enum AuditAction {
  USER_CREATED
  USER_VERIFIED
  USER_BLOCKED
  USER_UNBLOCKED
  PROFESSIONAL_APPROVED
  PROFESSIONAL_REJECTED
  PROPERTY_APPROVED
  PROPERTY_REJECTED
  CONTENT_FLAGGED
  ADMIN_ACCESS
  SETTINGS_CHANGED
  PAYMENT_PROCESSED
  PAYMENT_REFUNDED
}

enum AuditTargetType {
  USER
  PROFESSIONAL
  PROPERTY
  CONTENT
  PAYMENT
  SYSTEM
}

enum ClientStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum AdminRole {
  ADMIN_MASTER
  ADMIN_GERAL
  MODERADOR_CADASTROS
  MODERADOR_CONTEUDO
  SUPORTE
  FINANCEIRO
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                 String        @id @default(cuid())
  name               String?
  email              String        @unique
  emailVerified      DateTime?
  password           String?
  image              String?
  phone              String?
  phoneVerified      Boolean       @default(false)
  phoneVerifiedAt    DateTime?
  city               String?
  state              String?
  accountType        String        @default("client")
  document           String?
  birthDate          DateTime?
  role               UserRole      @default(GUEST)
  category           UserCategory?
  verified           Boolean       @default(false)
  credits            Float         @default(0)
  premiumUntil       DateTime?
  blocked            Boolean       @default(false)
  blockReason        String?
  blockedAt          DateTime?
  lgpdConsent        Boolean       @default(false)
  termsConsent       Boolean       @default(false)
  consentDate        DateTime?
  clientStatus       ClientStatus  @default(UNVERIFIED)
  kycSessionId       String?
  kycSubmittedAt     DateTime?
  kycReviewedAt      DateTime?
  kycRejectionReason String?
  kycIsSandbox       Boolean?
  kycChecksJson      Json?
  termsVersion       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  accounts                Account[]
  sessions                Session[]
  properties              Property[]
  bookingsAsGuest         Booking[]                   @relation("GuestBookings")
  reviews                 Review[]
  sentMessages            Message[]                   @relation("SentMessages")
  favorites               Favorite[]
  referrals               Referral[]                  @relation("ReferrerUser")
  referredBy              Referral?                   @relation("ReferredUser")
  hostProfile             HostProfile?
  clientProfile           ClientProfile?
  notifications           Notification[]
  professional            Professional?
  clientAppointments      Appointment[]               @relation("ClientAppointments")
  proReviews              ProfessionalReview[]        @relation("ProReviewAuthor")
  proReviewDisputes       ProfessionalReviewDispute[] @relation("ProReviewDisputeAuthor")
  stories                 Story[]
  reportsCreated          Report[]                    @relation("ReportAuthor")
  auditLogsCreated        AuditLog[]                  @relation("AuditAdmin")
  adminAssignments        AdminRoleAssignment[]       @relation("AdminRoleUser")
  adminRolesGranted       AdminRoleAssignment[]       @relation("AdminRoleGrantedBy")
  adminMfaEnrollment      AdminMfaEnrollment?
  adminMfaSessions        AdminMfaSession[]
  legalVersionsAuthored   LegalDocumentVersion[]      @relation("LegalVersionAuthor")
  legalVersionsApproved   LegalDocumentVersion[]      @relation("LegalVersionApprover")
  acceptances             UserAcceptance[]
  consentPreferences      ConsentPreference[]
  privacyRequests         PrivacyRequest[]
  contentDeclarations     ContentDeclaration[]
  checkoutAcceptances     CheckoutAcceptance[]
  deletionJobs            DataDeletionJob[]
  phoneVerificationCodes  PhoneVerificationCode[]
  payments                Payment[]
  claimedPremiumPurchases PremiumPurchaseIntent[]     @relation("PremiumPurchaseClaimedBy")
  voucherSpins            VoucherSpin[]               @relation("VoucherSpinClient")
  clientVouchers          ClientVoucher[]             @relation("ClientVouchers")
  uploadedAssets          UploadAsset[]               @relation("UploadOwner")
  reviewedAssets          UploadAsset[]               @relation("UploadReviewer")

  @@index([phone])
  @@index([accountType])
}

model PhoneVerificationCode {
  id                 String    @id @default(cuid())
  phone              String
  codeHash           String
  accountType        String    @default("client")
  channel            String    @default("sms")
  expiresAt          DateTime
  attempts           Int       @default(0)
  usedAt             DateTime?
  createdAt          DateTime  @default(now())
  sentAt             DateTime?
  deliveryProvider   String?
  providerMessageId  String?
  sendError          String?
  requestIp          String?
  termsConsent       Boolean   @default(false)
  lgpdConsent        Boolean   @default(false)
  ageConfirmed       Boolean   @default(false)
  ownershipConfirmed Boolean   @default(false)
  userId             String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, accountType, createdAt])
  @@index([phone, accountType, usedAt, expiresAt])
  @@index([requestIp, createdAt])
  @@index([expiresAt])
  @@index([expiresAt, createdAt])
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl  String
  mediaType String   @default("image")
  thumbnail String?
  expiresAt DateTime
  views     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model HostProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?
  bankName     String?
  bankAgency   String?
  bankAccount  String?
  bankPix      String?
  rating       Float    @default(0)
  totalReviews Int      @default(0)
  totalEarned  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id          String       @id @default(cuid())
  userId      String       @unique
  displayName String?
  status      ClientStatus @default(UNVERIFIED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Property ────────────────────────────────────────────────────────────────

model Property {
  id            String         @id @default(cuid())
  hostId        String
  title         String
  description   String         @db.Text
  type          PropertyType   @default(APARTMENT)
  status        PropertyStatus @default(DRAFT)
  address       String
  bairro        String?
  city          String
  state         String
  country       String         @default("Brasil")
  zipCode       String?
  latitude      Float?
  longitude     Float?
  pricePerNight Float
  cleaningFee   Float          @default(0)
  serviceFee    Float          @default(0)
  maxGuests     Int            @default(1)
  bedrooms      Int            @default(1)
  beds          Int            @default(1)
  bathrooms     Int            @default(1)
  checkInTime   String         @default("14:00")
  checkOutTime  String         @default("12:00")
  minNights     Int            @default(1)
  maxNights     Int?
  instantBook   Boolean        @default(false)
  allowPets     Boolean        @default(false)
  allowSmoking  Boolean        @default(false)
  allowParties  Boolean        @default(false)
  rating        Float          @default(0)
  totalReviews  Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  host            User              @relation(fields: [hostId], references: [id])
  photos          PropertyPhoto[]
  amenities       PropertyAmenity[]
  bookings        Booking[]
  reviews         Review[]
  blockedDates    BlockedDate[]
  favorites       Favorite[]
  seasonalPricing SeasonalPrice[]

  @@index([status, city])
  @@index([status, pricePerNight])
  @@index([hostId, status])
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyAmenity {
  id         String  @id @default(cuid())
  propertyId String
  name       String
  icon       String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  date       DateTime
  reason     String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
}

model SeasonalPrice {
  id         String   @id @default(cuid())
  propertyId String
  startDate  DateTime
  endDate    DateTime
  price      Float
  label      String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ─── Booking ─────────────────────────────────────────────────────────────────

model Booking {
  id                    String        @id @default(cuid())
  propertyId            String
  guestId               String
  checkIn               DateTime
  checkOut              DateTime
  guests                Int
  nights                Int
  pricePerNight         Float
  cleaningFee           Float         @default(0)
  serviceFee            Float         @default(0)
  discount              Float         @default(0)
  totalPrice            Float
  status                BookingStatus @default(PENDING)
  paymentStatus         PaymentStatus @default(PENDING)
  paymentId             String?
  paymentMethod         String?
  couponCode            String?
  notes                 String?       @db.Text
  hostPayout            Float?
  subtotalCents         Int?
  cleaningFeeCents      Int?
  serviceFeeCents       Int?
  discountCents         Int?
  totalPriceCents       Int?
  hostPayoutCents       Int?
  payoutStatus          String        @default("NOT_SCHEDULED")
  disputeStatus         String        @default("NONE")
  checkInStatus         String        @default("NOT_CONFIRMED")
  payoutBlocked         Boolean       @default(true)
  payoutBlockedReason   String?       @db.Text
  payoutEligibleAt      DateTime?
  contestationDeadline  DateTime?
  termsVersionId        String?
  refundPolicyVersionId String?
  acceptedAt            DateTime?
  acceptanceIp          String?
  acceptanceUserAgent   String?
  payoutDate            DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  property        Property                @relation(fields: [propertyId], references: [id])
  guest           User                    @relation("GuestBookings", fields: [guestId], references: [id])
  review          Review?
  messages        Message[]
  payments        Payment[]
  financialEvents BookingFinancialEvent[]

  @@index([guestId, status, createdAt])
  @@index([propertyId, status, checkIn, checkOut])
  @@index([paymentId])
}

model Payment {
  id                  String        @id @default(cuid())
  bookingId           String?
  userId              String?
  amount              Float
  currency            String        @default("BRL")
  method              String
  status              PaymentStatus @default(PENDING)
  provider            String        @default("asaas")
  providerPaymentId   String?       @unique
  externalReference   String?       @unique
  stripePaymentId     String?
  pixCode             String?
  pixQrCodeBase64     String?
  invoiceUrl          String?
  creditAmount        Float?
  premiumUntil        DateTime?
  boletoUrl           String?
  paidAt              DateTime?
  refundedAt          DateTime?
  refundAmount        Float?
  amountCents         Int?
  refundedAmountCents Int           @default(0)
  providerStatus      String?
  providerUpdatedAt   DateTime?
  expiresAt           DateTime?
  cancelledAt         DateTime?
  lastReconciledAt    DateTime?
  benefitStatus       String        @default("PENDING")
  benefitAppliedAt    DateTime?
  benefitReversedAt   DateTime?
  benefitError        String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  booking             Booking?               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user                User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucherUnlocks      ClientVoucher[]
  checkoutAcceptances CheckoutAcceptance[]
  operations          PaymentOperation[]
  premiumPurchase     PremiumPurchaseIntent?

  @@index([userId, status])
  @@index([bookingId, createdAt])
  @@index([provider, providerPaymentId])
}

model PremiumPurchaseIntent {
  id                     String    @id @default(cuid())
  paymentId              String    @unique
  planId                 String
  status                 String    @default("PAYMENT_PENDING")
  claimTokenHash         String    @unique
  purchaserName          String
  purchaserEmail         String
  purchaserPhone         String?
  purchaserDocumentHash  String
  purchaserDocumentLast4 String
  ipAddress              String?
  userAgent              String?   @db.Text
  termsVersionId         String?
  refundPolicyVersionId  String?
  termsHash              String
  refundPolicyHash       String
  acceptedAt             DateTime
  paidAt                 DateTime?
  claimedAt              DateTime?
  claimedByUserId        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  payment   Payment                @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  claimedBy User?                  @relation("PremiumPurchaseClaimedBy", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  events    PremiumPurchaseEvent[]

  @@index([purchaserEmail, status, createdAt])
  @@index([claimedByUserId, status])
  @@index([status, createdAt])
}

model PremiumPurchaseEvent {
  id        String   @id @default(cuid())
  intentId  String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  intent PremiumPurchaseIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@index([intentId, createdAt])
  @@index([type, createdAt])
}

model PaymentOperation {
  id               String    @id @default(cuid())
  paymentId        String
  adminId          String?
  type             String
  status           String    @default("PROCESSING")
  amountCents      Int?
  previousStatus   String?
  nextStatus       String?
  providerStatus   String?
  providerResponse Json?
  reason           String    @db.Text
  confirmation     String?
  idempotencyKey   String    @unique
  error            String?   @db.Text
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([paymentId, createdAt])
  @@index([type, status, createdAt])
  @@index([adminId, createdAt])
}

model BookingFinancialEvent {
  id               String   @id @default(cuid())
  bookingId        String
  paymentId        String?
  type             String
  status           String
  grossCents       Int?
  platformFeeCents Int?
  hostNetCents     Int?
  refundCents      Int?
  payoutCents      Int?
  reason           String?  @db.Text
  metadata         Json?
  createdAt        DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([bookingId, createdAt])
  @@index([paymentId, createdAt])
  @@index([type, status, createdAt])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String
  eventType   String?
  resourceId  String?
  status      String    @default("PROCESSING")
  attempts    Int       @default(1)
  payload     Json?
  error       String?   @db.Text
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([provider, eventId])
  @@index([provider, resourceId])
  @@index([status, createdAt])
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  propertyId    String
  authorId      String
  rating        Int
  cleanliness   Int      @default(5)
  accuracy      Int      @default(5)
  checkin       Int      @default(5)
  communication Int      @default(5)
  location      Int      @default(5)
  value         Int      @default(5)
  comment       String   @db.Text
  response      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id])
  author   User     @relation(fields: [authorId], references: [id])
}

// ─── Message ─────────────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  content   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation("SentMessages", fields: [senderId], references: [id])

  @@index([bookingId, createdAt])
  @@index([bookingId, read])
}

// ─── Favorite ────────────────────────────────────────────────────────────────

model Favorite {
  id             String   @id @default(cuid())
  userId         String
  propertyId     String?
  professionalId String?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property     Property?     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@unique([userId, professionalId])
  @@index([userId, createdAt])
  @@index([professionalId])
}

// ─── Coupon ──────────────────────────────────────────────────────────────────

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  description String?
  type        CouponType @default(PERCENTAGE)
  value       Float
  minBooking  Float?
  maxUses     Int?
  usedCount   Int        @default(0)
  expiresAt   DateTime?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─── Referral ────────────────────────────────────────────────────────────────

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique
  creditAmount Float    @default(0)
  paid         Boolean  @default(false)
  createdAt    DateTime @default(now())

  referrer User @relation("ReferrerUser", fields: [referrerId], references: [id])
  referred User @relation("ReferredUser", fields: [referredId], references: [id])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ─── Module 2: Marketplace de Profissionais ──────────────────────────────────

model Professional {
  id                String    @id @default(cuid())
  userId            String    @unique
  slug              String    @unique
  displayName       String
  bio               String    @db.Text
  city              String
  state             String
  bairro            String?
  phone             String?
  whatsapp          String?
  instagram         String?
  website           String?
  hidePhone         Boolean   @default(false)
  contactVisibility String    @default("PUBLIC")
  listingPhoneUntil DateTime?

  // Preços
  priceMin       Float?
  priceMax       Float?
  pricePerHour   Float?
  price30min     Float?
  price2h        Float?
  priceOvernight Float?
  priceWebcam    Float?
  paymentMethods String[]

  // Perfil físico
  escortCategory  String?
  birthDate       DateTime?
  hideAge         Boolean   @default(false)
  height          Int?
  weight          Int?
  hairColor       String?
  eyeColor        String?
  ethnicity       String?
  signo           String?
  hasTattoos      Boolean   @default(false)
  hasPiercing     Boolean   @default(false)
  hasSilicone     Boolean   @default(false)
  isDepilada      Boolean   @default(true)
  depilationStyle String?
  bodyType        String?

  // Atendimento
  attendanceTypes String[]
  servesGenders   String[]
  idiomas         String[]
  diasDisponiveis String[]
  horarioInicio   String?
  horarioFim      String?

  // Serviços
  services            String[]
  servicesNotOffered  String[] @default([])
  fetishes            String[]
  amenities           String[] @default([])
  serviceCities       String[] @default([])
  approximateLocation String?

  // Fotos
  image                         String?
  galleryUrls                   String[]
  presentationVideoUrl          String?
  presentationVideoStatus       String   @default("NONE") // NONE | PENDING | APPROVED | REJECTED
  presentationVideoRejectReason String?

  // Verificação de documentos (privado — nunca exposto ao cliente)
  docType          String?
  docFrenteUrl     String?
  docVersoUrl      String?
  docStatus        String  @default("NOT_SENT") // NOT_SENT | PENDING | APPROVED | REJECTED
  verifStatus      String  @default("NOT_SENT") // NOT_SENT | PENDING | APPROVED | REJECTED
  verificationUrl  String?
  verificationType String?
  verificationCode String?
  kycProvider      String?
  kycSessionId     String?
  kycStatus        String  @default("NOT_STARTED") // NOT_STARTED | PENDING | APPROVED | REJECTED | KYC_MANUAL_PENDENTE
  rejectReason     String?

  // Status e métricas
  status              ProfessionalStatus @default(PENDING_REVIEW)
  verified            Boolean            @default(false)
  featured            Boolean            @default(false)
  freeAccessStartedAt DateTime?
  freeAccessEndsAt    DateTime?
  accessGrandfathered Boolean            @default(true)
  pauseStartedAt      DateTime?
  pauseUntil          DateTime?
  pauseReason         String?
  boostActive         Boolean            @default(false)
  boostStartedAt      DateTime?
  boostUntil          DateTime?
  boostSource         String?
  activePlanId        String?
  planPriority        Int                @default(0)
  onlineVisible       Boolean            @default(true)
  lastOnlineAt        DateTime?
  profileViews        Int                @default(0)
  contactClicks       Int                @default(0)
  rating              Float              @default(0)
  totalReviews        Int                @default(0)
  totalAppointments   Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos          ProfessionalPhoto[]
  specialties     ProfessionalSpecialty[]
  schedule        Schedule[]
  appointments    Appointment[]
  reviews         ProfessionalReview[]
  reviewDisputes  ProfessionalReviewDispute[]
  profileEvents   ProfessionalProfileEvent[]
  favorites       Favorite[]
  voucherSettings ProfessionalVoucherSettings?

  @@index([status, featured, rating, totalReviews, createdAt])
  @@index([status, accessGrandfathered, freeAccessEndsAt])
  @@index([status, boostActive, boostUntil])
  @@index([status, planPriority, featured, rating])
  @@index([status, lastOnlineAt])
  @@index([status, listingPhoneUntil])
