generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProfessionalStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum UserRole {
  GUEST
  HOST
  ADMIN
}

enum UserCategory {
  HETERO
  TRANS
  MULHER
  HOMEM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PropertyStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  REJECTED
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  VILLA
  LOFT
  FARM
  HOTEL
  OTHER
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportReason {
  ILLEGAL_CONTENT
  FAKE_PROFILE
  HARASSMENT
  SCAM
  INAPPROPRIATE_CONTENT
  FAKE_DOCUMENTS
  OTHER
}

enum AuditAction {
  USER_CREATED
  USER_VERIFIED
  USER_BLOCKED
  USER_UNBLOCKED
  PROFESSIONAL_APPROVED
  PROFESSIONAL_REJECTED
  PROPERTY_APPROVED
  PROPERTY_REJECTED
  CONTENT_FLAGGED
  ADMIN_ACCESS
  SETTINGS_CHANGED
  PAYMENT_PROCESSED
  PAYMENT_REFUNDED
}

enum AuditTargetType {
  USER
  PROFESSIONAL
  PROPERTY
  CONTENT
  PAYMENT
  SYSTEM
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  name            String?
  email           String       @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  phone           String?
  document        String?
  birthDate       DateTime?
  role            UserRole     @default(GUEST)
  category        UserCategory?
  verified        Boolean      @default(false)
  credits         Float        @default(0)
  blocked         Boolean      @default(false)
  blockReason     String?
  blockedAt       DateTime?
  lgpdConsent     Boolean      @default(false)
  termsConsent    Boolean      @default(false)
  consentDate     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  accounts           Account[]
  sessions           Session[]
  properties         Property[]
  bookingsAsGuest    Booking[]      @relation("GuestBookings")
  reviews            Review[]
  sentMessages       Message[]      @relation("SentMessages")
  favorites          Favorite[]
  referrals          Referral[]     @relation("ReferrerUser")
  referredBy         Referral?      @relation("ReferredUser")
  hostProfile        HostProfile?
  notifications      Notification[]
  professional       Professional?
  clientAppointments Appointment[]  @relation("ClientAppointments")
  proReviews         ProfessionalReview[] @relation("ProReviewAuthor")
  stories            Story[]
  reportsCreated     Report[]       @relation("ReportAuthor")
  auditLogsCreated   AuditLog[]     @relation("AuditAdmin")
}

model Story {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl   String
  mediaType  String   @default("image")
  thumbnail  String?
  expiresAt  DateTime
  views      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model HostProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?
  bankName     String?
  bankAgency   String?
  bankAccount  String?
  bankPix      String?
  rating       Float    @default(0)
  totalReviews Int      @default(0)
  totalEarned  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Property ────────────────────────────────────────────────────────────────

model Property {
  id              String          @id @default(cuid())
  hostId          String
  title           String
  description     String          @db.Text
  type            PropertyType    @default(APARTMENT)
  status          PropertyStatus  @default(DRAFT)
  address         String
  bairro          String?
  city            String
  state           String
  country         String          @default("Brasil")
  zipCode         String?
  latitude        Float?
  longitude       Float?
  pricePerNight   Float
  cleaningFee     Float           @default(0)
  serviceFee      Float           @default(0)
  maxGuests       Int             @default(1)
  bedrooms        Int             @default(1)
  beds            Int             @default(1)
  bathrooms       Int             @default(1)
  checkInTime     String          @default("14:00")
  checkOutTime    String          @default("12:00")
  minNights       Int             @default(1)
  maxNights       Int?
  instantBook     Boolean         @default(false)
  allowPets       Boolean         @default(false)
  allowSmoking    Boolean         @default(false)
  allowParties    Boolean         @default(false)
  rating          Float           @default(0)
  totalReviews    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  host            User            @relation(fields: [hostId], references: [id])
  photos          PropertyPhoto[]
  amenities       PropertyAmenity[]
  bookings        Booking[]
  reviews         Review[]
  blockedDates    BlockedDate[]
  favorites       Favorite[]
  seasonalPricing SeasonalPrice[]
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  icon       String?

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  date       DateTime
  reason     String?

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
}

model SeasonalPrice {
  id         String   @id @default(cuid())
  propertyId String
  startDate  DateTime
  endDate    DateTime
  price      Float
  label      String?

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ─── Booking ─────────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  propertyId    String
  guestId       String
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  nights        Int
  pricePerNight Float
  cleaningFee   Float         @default(0)
  serviceFee    Float         @default(0)
  discount      Float         @default(0)
  totalPrice    Float
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?
  paymentMethod String?
  couponCode    String?
  notes         String?       @db.Text
  hostPayout    Float?
  payoutDate    DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  property      Property      @relation(fields: [propertyId], references: [id])
  guest         User          @relation("GuestBookings", fields: [guestId], references: [id])
  review        Review?
  messages      Message[]
  payment       Payment?
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  amount          Float
  currency        String        @default("BRL")
  method          String
  status          PaymentStatus @default(PENDING)
  stripePaymentId String?
  pixCode         String?
  boletoUrl       String?
  paidAt          DateTime?
  refundedAt      DateTime?
  refundAmount    Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  propertyId    String
  authorId      String
  rating        Int
  cleanliness   Int      @default(5)
  accuracy      Int      @default(5)
  checkin       Int      @default(5)
  communication Int      @default(5)
  location      Int      @default(5)
  value         Int      @default(5)
  comment       String   @db.Text
  response      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  property      Property @relation(fields: [propertyId], references: [id])
  author        User     @relation(fields: [authorId], references: [id])
}

// ─── Message ─────────────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  content   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
}

// ─── Favorite ────────────────────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

// ─── Coupon ──────────────────────────────────────────────────────────────────

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  description String?
  type        CouponType @default(PERCENTAGE)
  value       Float
  minBooking  Float?
  maxUses     Int?
  usedCount   Int        @default(0)
  expiresAt   DateTime?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─── Referral ────────────────────────────────────────────────────────────────

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique
  creditAmount Float    @default(0)
  paid         Boolean  @default(false)
  createdAt    DateTime @default(now())

  referrer     User     @relation("ReferrerUser", fields: [referrerId], references: [id])
  referred     User     @relation("ReferredUser", fields: [referredId], references: [id])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ─── Module 2: Marketplace de Profissionais ──────────────────────────────────

model Professional {
  id           String             @id @default(cuid())
  userId       String             @unique
  slug         String             @unique
  displayName  String
  bio          String             @db.Text
  city         String
  state        String
  bairro           String?
  phone        String?
  whatsapp     String?
  instagram    String?
  website      String?

  // Preços
  priceMin         Float?
  priceMax         Float?
  pricePerHour     Float?
  price30min       Float?
  price2h          Float?
  priceOvernight   Float?
  priceWebcam      Float?
  paymentMethods   String[]

  // Perfil físico
  escortCategory   String?
  birthDate        DateTime?
  height           Int?
  weight           Int?
  hairColor        String?
  eyeColor         String?
  ethnicity        String?
  signo            String?
  hasTattoos       Boolean  @default(false)
  hasSilicone      Boolean  @default(false)
  isDepilada       Boolean  @default(true)

  // Atendimento
  attendanceTypes  String[]
  servesGenders    String[]
  idiomas          String[]
  diasDisponiveis  String[]
  horarioInicio    String?
  horarioFim       String?

  // Serviços
  services         String[]
  fetishes         String[]

  // Fotos
  image            String?
  galleryUrls      String[]

  // Verificação de documentos (privado — nunca exposto ao cliente)
  docType          String?
  docFrenteUrl     String?
  docVersoUrl      String?
  docStatus        String   @default("NOT_SENT")  // NOT_SENT | PENDING | APPROVED | REJECTED
  verifStatus      String   @default("NOT_SENT")  // NOT_SENT | PENDING | APPROVED | REJECTED
  verificationUrl  String?
  verificationType String?
  verificationCode String?
  kycProvider      String?
  kycSessionId     String?
  kycStatus        String   @default("NOT_STARTED") // NOT_STARTED | PENDING | APPROVED | REJECTED | MANUAL_REVIEW
  rejectReason     String?

  // Status e métricas
  status            ProfessionalStatus @default(PENDING_REVIEW)
  verified          Boolean            @default(false)
  featured          Boolean            @default(false)
  rating            Float              @default(0)
  totalReviews      Int                @default(0)
  totalAppointments Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos       ProfessionalPhoto[]
  specialties  ProfessionalSpecialty[]
  schedule     Schedule[]
  appointments Appointment[]
  reviews      ProfessionalReview[]
}

model ProfessionalPhoto {
  id             String       @id @default(cuid())
  professionalId String
  url            String
  caption        String?
  order          Int          @default(0)
  cover          Boolean      @default(false)
  createdAt      DateTime     @default(now())

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model ProfessionalSpecialty {
  id             String       @id @default(cuid())
  professionalId String
  name           String
  icon           String?

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model Schedule {
  id             String       @id @default(cuid())
  professionalId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  available      Boolean      @default(true)

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
}

model Appointment {
  id             String            @id @default(cuid())
  professionalId String
  clientId       String
  date           DateTime
  duration       Int               @default(60)
  status         AppointmentStatus @default(PENDING)
  notes          String?           @db.Text
  contactMethod  String            @default("whatsapp")
  price          Float?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  professional   Professional       @relation(fields: [professionalId], references: [id])
  client         User               @relation("ClientAppointments", fields: [clientId], references: [id])
  review         ProfessionalReview?
}

model ProfessionalReview {
  id             String       @id @default(cuid())
  professionalId String
  appointmentId  String       @unique
  authorId       String
  rating         Int
  comment        String       @db.Text
  response       String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  professional   Professional @relation(fields: [professionalId], references: [id])
  appointment    Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  author         User         @relation("ProReviewAuthor", fields: [authorId], references: [id])
}

// ─── Moderação: Denúncias ────────────────────────────────────────────────────

model Report {
  id             String       @id @default(cuid())
  authorId       String
  targetType     String       // "USER", "PROFESSIONAL", "PROPERTY", "CONTENT"
  targetId       String
  reason         ReportReason
  description    String       @db.Text
  evidence       String[]     // URLs de imagens/screenshots
  status         ReportStatus @default(PENDING)
  reviewedBy     String?
  reviewNotes    String?      @db.Text
  resolution     String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  author         User         @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String           @id @default(cuid())
  adminId        String
  action         AuditAction
  targetType     AuditTargetType
  targetId       String
  changes        Json?
  reason         String?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime         @default(now())

  admin          User             @relation("AuditAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([timestamp])
}
