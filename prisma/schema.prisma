generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProfessionalStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  SUSPENDED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum UserRole {
  GUEST
  HOST
  ADMIN
}

enum UserCategory {
  HETERO
  TRANS
  MULHER
  HOMEM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PropertyStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  REJECTED
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  VILLA
  LOFT
  FARM
  HOTEL
  OTHER
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportReason {
  ILLEGAL_CONTENT
  FAKE_PROFILE
  HARASSMENT
  SCAM
  INAPPROPRIATE_CONTENT
  FAKE_DOCUMENTS
  OTHER
}

enum AuditAction {
  USER_CREATED
  USER_VERIFIED
  USER_BLOCKED
  USER_UNBLOCKED
  PROFESSIONAL_APPROVED
  PROFESSIONAL_REJECTED
  PROPERTY_APPROVED
  PROPERTY_REJECTED
  CONTENT_FLAGGED
  ADMIN_ACCESS
  SETTINGS_CHANGED
  PAYMENT_PROCESSED
  PAYMENT_REFUNDED
}

enum AuditTargetType {
  USER
  PROFESSIONAL
  PROPERTY
  CONTENT
  PAYMENT
  SYSTEM
}

enum ClientStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  name            String?
  email           String       @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  phone           String?
  phoneVerified   Boolean      @default(false)
  phoneVerifiedAt DateTime?
  city            String?
  state           String?
  accountType     String       @default("client")
  document        String?
  birthDate       DateTime?
  role            UserRole     @default(GUEST)
  category        UserCategory?
  verified        Boolean      @default(false)
  credits         Float        @default(0)
  premiumUntil    DateTime?
  blocked         Boolean      @default(false)
  blockReason     String?
  blockedAt       DateTime?
  lgpdConsent     Boolean      @default(false)
  termsConsent    Boolean      @default(false)
  consentDate     DateTime?
  clientStatus    ClientStatus @default(UNVERIFIED)
  kycSessionId       String?
  kycSubmittedAt     DateTime?
  kycReviewedAt      DateTime?
  kycRejectionReason String?
  kycIsSandbox       Boolean?
  kycChecksJson      Json?
  termsVersion       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  accounts           Account[]
  sessions           Session[]
  properties         Property[]
  bookingsAsGuest    Booking[]      @relation("GuestBookings")
  reviews            Review[]
  sentMessages       Message[]      @relation("SentMessages")
  favorites          Favorite[]
  referrals          Referral[]     @relation("ReferrerUser")
  referredBy         Referral?      @relation("ReferredUser")
  hostProfile        HostProfile?
  clientProfile      ClientProfile?
  notifications      Notification[]
  professional       Professional?
  clientAppointments Appointment[]  @relation("ClientAppointments")
  proReviews         ProfessionalReview[] @relation("ProReviewAuthor")
  proReviewDisputes  ProfessionalReviewDispute[] @relation("ProReviewDisputeAuthor")
  stories            Story[]
  reportsCreated     Report[]       @relation("ReportAuthor")
  auditLogsCreated   AuditLog[]     @relation("AuditAdmin")
  phoneVerificationCodes PhoneVerificationCode[]
  payments           Payment[]
  voucherSpins       VoucherSpin[]    @relation("VoucherSpinClient")
  clientVouchers     ClientVoucher[]  @relation("ClientVouchers")

  @@index([phone])
  @@index([accountType])
}

model PhoneVerificationCode {
  id          String    @id @default(cuid())
  phone       String
  codeHash    String
  accountType String    @default("client")
  channel     String    @default("sms")
  expiresAt   DateTime
  attempts    Int       @default(0)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  sentAt      DateTime?
  deliveryProvider String?
  providerMessageId String?
  sendError   String?
  requestIp   String?
  termsConsent Boolean   @default(false)
  lgpdConsent  Boolean   @default(false)
  ageConfirmed Boolean   @default(false)
  ownershipConfirmed Boolean @default(false)
  userId      String?

  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, accountType, createdAt])
  @@index([phone, accountType, usedAt, expiresAt])
  @@index([requestIp, createdAt])
  @@index([expiresAt])
}

model Story {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl   String
  mediaType  String   @default("image")
  thumbnail  String?
  expiresAt  DateTime
  views      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model HostProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?
  bankName     String?
  bankAgency   String?
  bankAccount  String?
  bankPix      String?
  rating       Float    @default(0)
  totalReviews Int      @default(0)
  totalEarned  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id          String       @id @default(cuid())
  userId      String       @unique
  displayName String?
  status      ClientStatus @default(UNVERIFIED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Property ────────────────────────────────────────────────────────────────

model Property {
  id              String          @id @default(cuid())
  hostId          String
  title           String
  description     String          @db.Text
  type            PropertyType    @default(APARTMENT)
  status          PropertyStatus  @default(DRAFT)
  address         String
  bairro          String?
  city            String
  state           String
  country         String          @default("Brasil")
  zipCode         String?
  latitude        Float?
  longitude       Float?
  pricePerNight   Float
  cleaningFee     Float           @default(0)
  serviceFee      Float           @default(0)
  maxGuests       Int             @default(1)
  bedrooms        Int             @default(1)
  beds            Int             @default(1)
  bathrooms       Int             @default(1)
  checkInTime     String          @default("14:00")
  checkOutTime    String          @default("12:00")
  minNights       Int             @default(1)
  maxNights       Int?
  instantBook     Boolean         @default(false)
  allowPets       Boolean         @default(false)
  allowSmoking    Boolean         @default(false)
  allowParties    Boolean         @default(false)
  rating          Float           @default(0)
  totalReviews    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  host            User            @relation(fields: [hostId], references: [id])
  photos          PropertyPhoto[]
  amenities       PropertyAmenity[]
  bookings        Booking[]
  reviews         Review[]
  blockedDates    BlockedDate[]
  favorites       Favorite[]
  seasonalPricing SeasonalPrice[]

  @@index([status, city])
  @@index([status, pricePerNight])
  @@index([hostId, status])
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  icon       String?

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  date       DateTime
  reason     String?

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
}

model SeasonalPrice {
  id         String   @id @default(cuid())
  propertyId String
  startDate  DateTime
  endDate    DateTime
  price      Float
  label      String?

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ─── Booking ─────────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  propertyId    String
  guestId       String
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  nights        Int
  pricePerNight Float
  cleaningFee   Float         @default(0)
  serviceFee    Float         @default(0)
  discount      Float         @default(0)
  totalPrice    Float
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?
  paymentMethod String?
  couponCode    String?
  notes         String?       @db.Text
  hostPayout    Float?
  payoutDate    DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  property      Property      @relation(fields: [propertyId], references: [id])
  guest         User          @relation("GuestBookings", fields: [guestId], references: [id])
  review        Review?
  messages      Message[]
  payment       Payment?

  @@index([guestId, status, createdAt])
  @@index([propertyId, status, checkIn, checkOut])
  @@index([paymentId])
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String?       @unique
  userId          String?
  amount          Float
  currency        String        @default("BRL")
  method          String
  status          PaymentStatus @default(PENDING)
  provider        String        @default("asaas")
  providerPaymentId String?     @unique
  externalReference String?     @unique
  stripePaymentId String?
  pixCode         String?
  pixQrCodeBase64 String?
  invoiceUrl      String?
  creditAmount    Float?
  premiumUntil    DateTime?
  boletoUrl       String?
  paidAt          DateTime?
  refundedAt      DateTime?
  refundAmount    Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking         Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucherUnlocks  ClientVoucher[]

  @@index([userId, status])
  @@index([provider, providerPaymentId])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String
  eventType   String?
  resourceId  String?
  status      String    @default("PROCESSING")
  attempts    Int       @default(1)
  payload     Json?
  error       String?   @db.Text
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([provider, eventId])
  @@index([provider, resourceId])
  @@index([status, createdAt])
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  propertyId    String
  authorId      String
  rating        Int
  cleanliness   Int      @default(5)
  accuracy      Int      @default(5)
  checkin       Int      @default(5)
  communication Int      @default(5)
  location      Int      @default(5)
  value         Int      @default(5)
  comment       String   @db.Text
  response      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  property      Property @relation(fields: [propertyId], references: [id])
  author        User     @relation(fields: [authorId], references: [id])
}

// ─── Message ─────────────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  content   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
}

// ─── Favorite ────────────────────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String?
  professionalId String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@unique([userId, professionalId])
  @@index([professionalId])
}

// ─── Coupon ──────────────────────────────────────────────────────────────────

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  description String?
  type        CouponType @default(PERCENTAGE)
  value       Float
  minBooking  Float?
  maxUses     Int?
  usedCount   Int        @default(0)
  expiresAt   DateTime?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─── Referral ────────────────────────────────────────────────────────────────

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique
  creditAmount Float    @default(0)
  paid         Boolean  @default(false)
  createdAt    DateTime @default(now())

  referrer     User     @relation("ReferrerUser", fields: [referrerId], references: [id])
  referred     User     @relation("ReferredUser", fields: [referredId], references: [id])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ─── Module 2: Marketplace de Profissionais ──────────────────────────────────

model Professional {
  id           String             @id @default(cuid())
  userId       String             @unique
  slug         String             @unique
  displayName  String
  bio          String             @db.Text
  city         String
  state        String
  bairro           String?
  phone        String?
  whatsapp     String?
  instagram    String?
  website      String?
  hidePhone    Boolean @default(false)
  listingPhoneUntil DateTime?

  // Preços
  priceMin         Float?
  priceMax         Float?
  pricePerHour     Float?
  price30min       Float?
  price2h          Float?
  priceOvernight   Float?
  priceWebcam      Float?
  paymentMethods   String[]

  // Perfil físico
  escortCategory   String?
  birthDate        DateTime?
  hideAge          Boolean  @default(false)
  height           Int?
  weight           Int?
  hairColor        String?
  eyeColor         String?
  ethnicity        String?
  signo            String?
  hasTattoos       Boolean  @default(false)
  hasPiercing      Boolean  @default(false)
  hasSilicone      Boolean  @default(false)
  isDepilada       Boolean  @default(true)
  depilationStyle  String?
  bodyType         String?

  // Atendimento
  attendanceTypes  String[]
  servesGenders    String[]
  idiomas          String[]
  diasDisponiveis  String[]
  horarioInicio    String?
  horarioFim       String?

  // Serviços
  services         String[]
  fetishes         String[]

  // Fotos
  image            String?
  galleryUrls      String[]
  presentationVideoUrl          String?
  presentationVideoStatus       String   @default("NONE") // NONE | PENDING | APPROVED | REJECTED
  presentationVideoRejectReason String?

  // Verificação de documentos (privado — nunca exposto ao cliente)
  docType          String?
  docFrenteUrl     String?
  docVersoUrl      String?
  docStatus        String   @default("NOT_SENT")  // NOT_SENT | PENDING | APPROVED | REJECTED
  verifStatus      String   @default("NOT_SENT")  // NOT_SENT | PENDING | APPROVED | REJECTED
  verificationUrl  String?
  verificationType String?
  verificationCode String?
  kycProvider      String?
  kycSessionId     String?
  kycStatus        String   @default("NOT_STARTED") // NOT_STARTED | PENDING | APPROVED | REJECTED | KYC_MANUAL_PENDENTE
  rejectReason     String?

  // Status e métricas
  status            ProfessionalStatus @default(PENDING_REVIEW)
  verified          Boolean            @default(false)
  featured          Boolean            @default(false)
  pauseStartedAt    DateTime?
  pauseUntil        DateTime?
  pauseReason       String?
  boostActive       Boolean            @default(false)
  boostStartedAt    DateTime?
  boostUntil        DateTime?
  boostSource       String?
  profileViews      Int                @default(0)
  contactClicks     Int                @default(0)
  rating            Float              @default(0)
  totalReviews      Int                @default(0)
  totalAppointments Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos       ProfessionalPhoto[]
  specialties  ProfessionalSpecialty[]
  schedule     Schedule[]
  appointments Appointment[]
  reviews      ProfessionalReview[]
  reviewDisputes ProfessionalReviewDispute[]
  profileEvents ProfessionalProfileEvent[]
  favorites    Favorite[]
  voucherSettings ProfessionalVoucherSettings?

  @@index([status, featured, rating, totalReviews, createdAt])
  @@index([status, boostActive, boostUntil])
  @@index([status, listingPhoneUntil])
  @@index([status, city])
  @@index([status, escortCategory])
  @@index([status, priceMin])
}

model ProfessionalProfileEvent {
  id             String       @id @default(cuid())
  professionalId String
  eventType      String
  metadata       Json?
  createdAt      DateTime     @default(now())

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, eventType, createdAt])
  @@index([createdAt])
}

model ProfessionalPhoto {
  id             String       @id @default(cuid())
  professionalId String
  url            String
  caption        String?
  order          Int          @default(0)
  cover          Boolean      @default(false)
  createdAt      DateTime     @default(now())

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model ProfessionalSpecialty {
  id             String       @id @default(cuid())
  professionalId String
  name           String
  icon           String?

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model Schedule {
  id             String       @id @default(cuid())
  professionalId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  available      Boolean      @default(true)

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
}

model Appointment {
  id             String            @id @default(cuid())
  professionalId String
  clientId       String
  date           DateTime
  duration       Int               @default(60)
  status         AppointmentStatus @default(PENDING)
  notes          String?           @db.Text
  contactMethod  String            @default("whatsapp")
  price          Float?
  originalPrice  Float?
  voucherDiscount Float             @default(0)
  finalPrice     Float?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  professional   Professional       @relation(fields: [professionalId], references: [id])
  client         User               @relation("ClientAppointments", fields: [clientId], references: [id])
  review         ProfessionalReview?
  voucher        ClientVoucher?      @relation("AppointmentVoucher")

  @@index([clientId, status, createdAt])
  @@index([professionalId, status, date])
}

model ProfessionalReview {
  id             String       @id @default(cuid())
  professionalId String
  appointmentId  String       @unique
  authorId       String
  rating         Int
  comment        String       @db.Text
  response       String?      @db.Text
  hidden         Boolean      @default(false)
  moderationStatus String     @default("VISIBLE") // VISIBLE | DISPUTED | REMOVED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  professional   Professional @relation(fields: [professionalId], references: [id])
  appointment    Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  author         User         @relation("ProReviewAuthor", fields: [authorId], references: [id])
  dispute        ProfessionalReviewDispute?
}

model VoucherSettings {
  id                  String   @id @default("default")
  active              Boolean  @default(true)
  dailySpinLimit      Int      @default(1)
  guestDailySpinLimit Int      @default(1)
  pendingClaimMinutes Int      @default(30)
  defaultExpiresInDays Int     @default(15)
  monthlyBudgetLimit  Float    @default(3000)
  dailyBudgetLimit    Float    @default(100)
  dailyBudgetMode     String   @default("BLOCK_FREE_VOUCHERS")
  voucherWinCooldownDays Int   @default(7)
  blockMultipleActiveVouchers Boolean @default(true)
  registrationClaimHours Int   @default(24)
  allowMultipleVouchersPerAppointment Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model VoucherBudget {
  id           String   @id @default(cuid())
  month        Int
  year         Int
  monthlyLimit Float    @default(3000)
  dailyLimit   Float    @default(100)
  monthlyUsed  Float    @default(0)
  dailyUsed    Float    @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([month, year])
  @@index([year, month, active])
}

model VoucherPrize {
  id              String   @id @default(cuid())
  name            String
  type            String
  value           Float?
  probability     Float
  baseProbability Float    @default(0)
  currentProbability Float @default(0)
  monthlyQuantityLimit Int?
  monthlyQuantityUsed Int  @default(0)
  dailyQuantityLimit Int?
  dailyQuantityUsed Int   @default(0)
  weeklyQuantityLimit Int?
  active          Boolean  @default(true)
  requiresPayment Boolean  @default(false)
  paymentAmount   Float?
  expiresInDays   Int      @default(15)
  expiresInHours  Int?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  spins           VoucherSpin[]
  vouchers        ClientVoucher[]

  @@index([active, sortOrder])
}

model VoucherSpin {
  id              String   @id @default(cuid())
  clientId        String?
  visitorId       String?
  prizeId         String?
  result          String
  voucherValue    Float?
  whatsapp        String?
  ipAddress       String?
  userAgent       String?  @db.Text
  idempotencyKey  String   @unique
  pendingToken    String?  @unique
  pendingExpiresAt DateTime?
  claimedAt       DateTime?
  recipientName   String?
  recipientPhone  String?
  createdAt       DateTime @default(now())

  client          User?        @relation("VoucherSpinClient", fields: [clientId], references: [id], onDelete: SetNull)
  prize           VoucherPrize? @relation(fields: [prizeId], references: [id], onDelete: SetNull)
  vouchers        ClientVoucher[]

  @@index([clientId, createdAt])
  @@index([visitorId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([result, createdAt])
}

model ClientVoucher {
  id              String   @id @default(cuid())
  clientId        String?
  visitorId       String?
  prizeId         String?
  spinId          String?
  code            String   @unique
  value           Float
  status          String   @default("AVAILABLE")
  expiresAt       DateTime
  usedAt          DateTime?
  appointmentId   String?  @unique
  requiresPayment Boolean  @default(false)
  paymentStatus   String   @default("NOT_REQUIRED")
  paymentId       String?
  whatsapp        String?
  registrationRequired Boolean @default(false)
  registrationReleasedAt DateTime?
  recipientName   String?
  recipientPhone  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          User?         @relation("ClientVouchers", fields: [clientId], references: [id], onDelete: SetNull)
  prize           VoucherPrize? @relation(fields: [prizeId], references: [id], onDelete: SetNull)
  spin            VoucherSpin?  @relation(fields: [spinId], references: [id], onDelete: SetNull)
  appointment     Appointment?  @relation("AppointmentVoucher", fields: [appointmentId], references: [id], onDelete: SetNull)
  payment         Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([clientId, status, expiresAt])
  @@index([visitorId, status, expiresAt])
  @@index([recipientPhone, status])
  @@index([paymentStatus])
}

model ProfessionalVoucherSettings {
  id              String   @id @default(cuid())
  professionalId  String   @unique
  acceptsVouchers Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  professional    Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model ProfessionalReviewDispute {
  id             String             @id @default(cuid())
  reviewId       String             @unique
  professionalId String
  authorId       String
  status         String             @default("PENDING") // PENDING | ACCEPTED | REJECTED
  reason         String             @db.Text
  adminNote      String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  review         ProfessionalReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  professional   Professional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  author         User               @relation("ProReviewDisputeAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([professionalId, status, createdAt])
  @@index([status, createdAt])
}

// ─── Moderação: Denúncias ────────────────────────────────────────────────────

model Report {
  id             String       @id @default(cuid())
  authorId       String
  targetType     String       // "USER", "PROFESSIONAL", "PROPERTY", "CONTENT"
  targetId       String
  reason         ReportReason
  description    String       @db.Text
  evidence       String[]     // URLs de imagens/screenshots
  status         ReportStatus @default(PENDING)
  reviewedBy     String?
  reviewNotes    String?      @db.Text
  resolution     String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  author         User         @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String           @id @default(cuid())
  adminId        String
  action         AuditAction
  targetType     AuditTargetType
  targetId       String
  changes        Json?
  reason         String?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime         @default(now())

  admin          User             @relation("AuditAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([timestamp])
}
